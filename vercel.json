{
  "rewrites": [
    { "source": "/privacy", "destination": "/charcount/privacy.html" },
    { "source": "/support", "destination": "/charcount/support.html" },
    { "source": "/charcount/:path*", "destination": "/charcount/:path*" },
    { "source": "/ironlog/support", "destination": "/ironlog/support.html" },
    { "source": "/ironlog/privacy", "destination": "/ironlog/privacy.html" },
    { "source": "/ironlog/:path*", "destination": "/ironlog/:path*" },
    { "source": "/legal/:path*", "destination": "/legal/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
